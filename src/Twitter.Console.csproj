<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>twitter</ToolCommandName>
    <PackageId>Twitter.Console</PackageId>
    <Version>0.0.0-local</Version>
    <Authors>nielsbosma</Authors>
    <Description>CLI for searching and scraping Twitter/X via Apify — YAML-first output optimized for LLM agent consumption.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/nielsbosma/Twitter.Console</RepositoryUrl>
    <PackageTags>cli;dotnet-tool;twitter</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Spectre.Console.Cli" Version="1.0.0-alpha.0.16" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
  </ItemGroup>
</Project>
